Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
      Splitter Ratio: 0.8
    Tree Height: 300
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
Visualization Manager:
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Plane Cell Count: 30
      Enabled: true
    - Class: rviz_default_plugins/Map
      Name: Map
      Topic: /map
      Enabled: true
    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true
    - Class: rviz_default_plugins/LaserScan
      Color: 255; 0; 0
      Name: LaserScan
      Size (m): 0.05
      Topic: /scan
      Enabled: true
    - Class: rviz_default_plugins/RobotModel
      Collision Enabled: false
      Description Source: Topic
      Description Topic: /robot_description
      Enabled: true
      Name: RobotModel
      Visual Enabled: true
    - Class: rviz_default_plugins/Pose
      Enabled: true
      Name: Pose (AMCL estimate)
      Topic: /amcl_node/pose
    - Class: rviz_default_plugins/PoseWithCovariance
      Enabled: true
      Name: PoseWithCovariance (AMCL uncertainty)
      Topic: /amcl_node/amcl_pose
    - Class: rviz_default_plugins/PoseArray
      Enabled: true
      Name: Particle Cloud (AMCL)
      Topic: /amcl_node/particle_cloud
    - Class: rviz_default_plugins/Path
      Color: 0; 255; 0
      Name: Path (AMCL trajectory)
      Topic: /amcl_node/path
      Enabled: true
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetInitialPose
    - Class: rviz_default_plugins/SetGoal
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: Current View
      Near Clip Distance: 0.01
      Pitch: 1.29
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz_default_plugins)
      Yaw: 3.160400390625
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 594
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Time:
    collapsed: false
  Width: 1453
  X: 95
  Y: 122
